font-family = "ComicShannsMono Nerd Font Mono"
font-size = 19

command = /usr/bin/fish
shell-integration = fish
background-opacity = 0.9
window-inherit-working-directory = true
window-inherit-font-size = true
copy-on-select = true

# Match kitty keybindings where Ghostty has equivalent actions.
keybind = clear

# Basic terminal operations
keybind = ctrl+shift+c=copy_to_clipboard
keybind = ctrl+shift+v=paste_from_clipboard

# Navigation
keybind = f11=toggle_fullscreen
keybind = alt+left=text:\x1bOH
keybind = alt+right=text:\x1bOF
keybind = alt+backspace=text:\x15

# Tabs
keybind = alt+t=new_tab
keybind = alt+w=close_tab:this
keybind = alt+c=close_surface
keybind = alt+bracket_left=previous_tab
keybind = alt+bracket_right=next_tab
keybind = alt+0=prompt_surface_title

# Windows and splits
keybind = alt+n=new_window
keybind = alt+backslash=new_split:right
keybind = alt+ctrl+backslash=new_split:down
keybind = alt+ctrl+h=goto_split:left
keybind = alt+ctrl+l=goto_split:right
keybind = alt+ctrl+k=goto_split:up
keybind = alt+ctrl+j=goto_split:down
keybind = ctrl+shift+bracket_right=goto_split:next
keybind = ctrl+shift+bracket_left=goto_split:previous
keybind = alt+enter=toggle_split_zoom
keybind = alt+ctrl+r=equalize_splits

# Scrolling
keybind = page_up=scroll_page_up
keybind = page_down=scroll_page_down
keybind = ctrl+shift+home=scroll_to_top
keybind = ctrl+shift+end=scroll_to_bottom

# Font size
keybind = ctrl+shift+equal=increase_font_size:1
keybind = ctrl+shift+minus=decrease_font_size:1
keybind = ctrl+shift+0=reset_font_size

# Utilities
keybind = ctrl+shift+p=toggle_command_palette
keybind = ctrl+shift+f5=reload_config
keybind = ctrl+shift+f6=inspector:toggle
