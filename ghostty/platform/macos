# macOS-specific Ghostty settings.
command = /bin/zsh
shell-integration = zsh

# Navigation
keybind = cmd+left=text:\x1bOH
keybind = cmd+right=text:\x1bOF
keybind = cmd+backspace=text:\x15

# Clipboard
keybind = cmd+c=copy_to_clipboard
keybind = cmd+v=paste_from_clipboard

# Tabs
keybind = cmd+t=new_tab
keybind = cmd+w=close_tab:this
keybind = cmd+bracket_left=previous_tab
keybind = cmd+bracket_right=next_tab
keybind = cmd+0=prompt_surface_title

# Windows and splits
keybind = cmd+n=new_window
keybind = cmd+backslash=new_split:right
keybind = cmd+ctrl+backslash=new_split:down
keybind = cmd+ctrl+h=goto_split:left
keybind = cmd+ctrl+l=goto_split:right
keybind = cmd+ctrl+k=goto_split:up
keybind = cmd+ctrl+j=goto_split:down
keybind = cmd+enter=toggle_split_zoom
keybind = cmd+ctrl+r=equalize_splits
